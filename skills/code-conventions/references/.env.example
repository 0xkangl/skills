# =============================================================================
# .env.example — annotated configuration template
# Source of truth: code-conventions skill, configuration.md §3.
#
# Rules:
#   - Commit this file; NEVER commit a real .env. Values here are placeholders.
#   - Tags:  [REQUIRED] startup fails without it
#            [OPTIONAL] safe default shown
#            [COND]     required only when the related feature is enabled
#   - Generate 256-bit secrets with:  openssl rand -hex 32
#   - Keep in sync: add/rename/remove a var here in the SAME change as the code,
#     placed in the correct group + importance order (configuration.md §2, §3).
# Groups are ordered by boot-criticality.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Core Runtime
# -----------------------------------------------------------------------------
APP_ENV=development            # [REQUIRED] development | staging | production
PORT=8080                      # [REQUIRED] main HTTP listener
LOG_FORMAT=json                # [OPTIONAL] json (default) | text (local dev only)
LOG_LEVEL=info                 # [OPTIONAL] debug | info (default) | warn | error
METRICS_PORT=0                 # [OPTIONAL] 0 = /metrics on PORT; 9090 = dedicated listener

# -----------------------------------------------------------------------------
# 2. Data Store
# -----------------------------------------------------------------------------
# [REQUIRED] sslmode=require in production
DATABASE_URL=postgres://user:pass@localhost:5432/app?sslmode=disable

# -----------------------------------------------------------------------------
# 3. Security & Secrets   (all via: openssl rand -hex 32 — never log, never commit)
# -----------------------------------------------------------------------------
# [REQUIRED] general-purpose, TRANSIENT business secret; HKDF-derive per purpose.
#            Short rotation cadence (nothing long-lived depends on it).
APP_PEPPER=

# [REQUIRED] DEDICATED JWT signing key — NOT derived from APP_PEPPER.
#            Rotate rarely + with kid overlap (see configuration.md §6.2).
JWT_SIGNING_KEY=

# [COND] required for data encrypted AT REST in the DB. Dedicated + long-lived;
#        rotate only via a re-encryption migration. One per purpose, e.g.:
# PII_ENCRYPTION_KEY=

# [COND] required if a module exposes internal (module-to-module) endpoints.
#        Sent as `Authorization: Internal <token>`. One per module, e.g.:
# BILLING_INTERNAL_TOKEN=

# JWT token lifetimes (durations). [OPTIONAL] — defaults shown.
JWT_ACCESS_TTL=24h             # mobile / native / default access token
JWT_REFRESH_TTL=720h           # mobile / native / default refresh token (30d)
JWT_WEB_ACCESS_TTL=15m         # web access token (falls back to JWT_ACCESS_TTL)
JWT_WEB_REFRESH_TTL=24h        # web refresh token (falls back to JWT_REFRESH_TTL)

# -----------------------------------------------------------------------------
# 4. Cache / Queue
# -----------------------------------------------------------------------------
# [COND] required if cache / session / rate-limit is used
REDIS_URL=redis://localhost:6379/0
# Project prefix for shared infra. Empty OK for local single-tenant;
# MUST be set on shared/prod infra. Module prefix is fixed in code (§4).
CACHE_PREFIX=acme              # [COND]
QUEUE_PREFIX=acme              # [COND] required when a shared broker is used

# -----------------------------------------------------------------------------
# 5. Localization
# -----------------------------------------------------------------------------
DEFAULT_LOCALE=en              # [OPTIONAL] fallback when Accept-Language absent/unmatched
SUPPORTED_LOCALES=en,zh-Hans,zh-Hant   # [OPTIONAL] script-based content locales only

# -----------------------------------------------------------------------------
# 6. Third-Party Integrations   (provider selection; `stub` is one provider)
# -----------------------------------------------------------------------------
# [OPTIONAL] default `stub` (logs intended calls, no real I/O).
#            staging/prod MUST pick a real impl; APP_ENV=production rejects `stub`.
SMS_PROVIDER=stub              # stub | twilio | ...
# [COND] required when a real impl is selected:
# SMS_API_KEY=
