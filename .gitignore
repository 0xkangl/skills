# OS
.DS_Store
Thumbs.db

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo

# Node (scripts are zero-dependency, but ignore accidental installs)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Tooling
# skills-lock.json and .agents/ are local state for installed skills;
# treat them like a package cache and keep them out of the repo.
skills-lock.json
.agents/
.claude/settings.local.json
# ignore installed-skill caches, but keep this repo's own project skills tracked
.claude/skills/*
!.claude/skills/skill-check/
!.claude/skills/new-skill/

# Logs & temp
*.log
/tmp/

# 外部参考仓库(本地 clone,不入库)
ref-repo/
